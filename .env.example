# Admin Authentication
# Generate hash with: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=

# Session Secret (random string, at least 32 chars)
SESSION_SECRET=

# Tencent Cloud COS
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_DOMAIN=

# Public API Token (for unauthenticated image access)
PUBLIC_API_TOKEN=
PUBLIC_BASE_URL=

# Minimax AI
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com
